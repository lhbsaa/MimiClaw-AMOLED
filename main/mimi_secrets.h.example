/*
 * MimiClaw-AMOLED Build-time Secrets
 *
 * This is the ONLY way to configure MimiClaw-AMOLED.
 * Copy this file to mimi_secrets.h and fill in your values.
 * After any change, rebuild: idf.py fullclean && idf.py build
 *
 *   cp mimi_secrets.h.example mimi_secrets.h
 */

#pragma once

/* WiFi */
#define MIMI_SECRET_WIFI_SSID       ""
#define MIMI_SECRET_WIFI_PASS       ""

/* Telegram Bot */
#define MIMI_SECRET_TG_TOKEN        ""

/* Feishu Bot */
#define MIMI_SECRET_FEISHU_APP_ID   ""
#define MIMI_SECRET_FEISHU_APP_SECRET ""

/* ============================================================================
 * LLM Provider Configuration
 * ============================================================================
 * 
 * Supported providers: anthropic, openai, openrouter, ollama
 * 
 * Option 1: Anthropic Claude (default)
 *   - Set MIMI_SECRET_MODEL_PROVIDER to "anthropic"
 *   - Set MIMI_SECRET_API_KEY to your Anthropic API key
 *   - Set MIMI_SECRET_MODEL to e.g. "claude-sonnet-4-20250514"
 * 
 * Option 2: OpenAI
 *   - Set MIMI_SECRET_MODEL_PROVIDER to "openai"
 *   - Set MIMI_SECRET_API_KEY to your OpenAI API key
 *   - Set MIMI_SECRET_MODEL to e.g. "gpt-4o"
 * 
 * Option 3: OpenRouter
 *   - Set MIMI_SECRET_MODEL_PROVIDER to "openrouter"
 *   - Set MIMI_SECRET_API_KEY to your OpenRouter API key
 *   - Set MIMI_SECRET_MODEL to e.g. "anthropic/claude-sonnet-4"
 * 
 * Option 4: Ollama (Local LLM)
 *   - Set MIMI_SECRET_MODEL_PROVIDER to "ollama"
 *   - Set MIMI_SECRET_OLLAMA_HOST to your Ollama server IP (e.g. "192.168.1.100")
 *   - Set MIMI_SECRET_OLLAMA_PORT to Ollama port (default "11434")
 *   - Set MIMI_SECRET_OLLAMA_MODEL to the model name (e.g. "llama3.2", "qwen2.5")
 *   - MIMI_SECRET_API_KEY can be empty or "ollama" (not used by Ollama)
 */

#define MIMI_SECRET_API_KEY         ""
#define MIMI_SECRET_MODEL           ""
#define MIMI_SECRET_MODEL_PROVIDER  "ollama"    /* anthropic, openai, openrouter, ollama */

/* Ollama Configuration (only used when provider is "ollama") */
#define MIMI_SECRET_OLLAMA_HOST     "192.168.1.100"   /* Your PC/Phone IP running Ollama */
#define MIMI_SECRET_OLLAMA_PORT     "11434"           /* Ollama default port */
#define MIMI_SECRET_OLLAMA_MODEL    "llama3.2"        /* Model name: llama3.2, qwen2.5, gemma2, etc. */

/* HTTP Proxy (leave empty or set both) */
#define MIMI_SECRET_PROXY_HOST      ""
#define MIMI_SECRET_PROXY_PORT      ""
#define MIMI_SECRET_PROXY_TYPE      ""   /* "http" or "socks5" */

/* Brave Search API */
#define MIMI_SECRET_SEARCH_KEY      ""

/* Tavily Search API */
#define MIMI_SECRET_TAVILY_KEY      ""